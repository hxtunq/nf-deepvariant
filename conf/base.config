/*
 * ========================================
 *  Cấu hình tài nguyên nền
 *  Tối ưu tương đối cho máy 16GB RAM, 4 core / 8 thread
 * ========================================
 */

process {
    // Cách xử lý lỗi.
    errorStrategy = 'finish'
    maxRetries    = 0
    maxErrors     = '-1'

    // Tài nguyên mặc định; đặt bảo thủ cho máy 16GB RAM.
    cpus   = { Math.min(2 * task.attempt, params.max_cpus ?: 8) }
    memory = { 4.GB }
    time   = { 4.h }

    // Nhãn tài nguyên.
    withLabel:process_single {
        cpus   = { Math.min(1, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 4.h }
    }

    withLabel:process_low {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 4.GB }
        time   = { 4.h }
    }

    withLabel:process_medium {
        cpus   = { Math.min(4, params.max_cpus ?: 8) }
        memory = { 8.GB }
        time   = { 8.h }
    }

    withLabel:process_high {
        cpus   = { Math.min(6, params.max_cpus ?: 8) }
        memory = { 12.GB }
        time   = { 16.h }
    }

    withLabel:process_long {
        time   = { 20.h }
    }

    withLabel:process_high_memory {
        cpus   = { Math.min(4, params.max_cpus ?: 8) }
        memory = { 14.GB }
        time   = { 20.h }
    }

    // Tài nguyên riêng cho từng process; tối ưu cho máy 16GB RAM.
    withName: 'FASTQC' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 2.h }
    }

    withName: 'FASTP' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 4.GB }
        time   = { 2.h }
    }

    withName: 'BWA_MEM2' {
        cpus   = { Math.min(6, params.max_cpus ?: 8) }
        memory = { 8.GB }
        time   = { 12.h }
    }

    withName: 'SAMTOOLS_SORT' {
        cpus   = { Math.min(4, params.max_cpus ?: 8) }
        memory = { 6.GB }
        time   = { 6.h }
    }

    withName: 'SAMTOOLS_INDEX' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 4.GB }
        time   = { 2.h }
    }

    withName: 'DEEPVARIANT' {
        cpus   = { Math.min(6, params.max_cpus ?: 8) }
        memory = { 10.GB }
        time   = { 16.h }
    }

    withName: 'MULTIQC' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 4.GB }
        time   = { 2.h }
    }

    // ============================================================
    //  Các process kiểm tra QC
    // ============================================================
    withName: 'SAMTOOLS_FLAGSTAT' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 1.h }
    }

    withName: 'SAMTOOLS_STATS' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 1.h }
    }

    withName: 'SAMTOOLS_IDXSTATS' {
        cpus   = { Math.min(1, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 1.h }
    }

    withName: 'BAM_QC' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 4.GB }
        time   = { 2.h }
    }

    withName: 'BCFTOOLS_STATS' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 1.h }
    }

    withName: 'VCF_VALIDATION' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 1.h }
    }

    withName: 'FASTQ_VALIDATION' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 1.h }
    }
}
