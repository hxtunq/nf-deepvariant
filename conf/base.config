/*
 * ========================================
 *  Base resource configuration
 *  Optimized for 16GB RAM, 4 cores / 8 threads
 * ========================================
 */

process {
    // Error handling
    errorStrategy = 'finish'
    maxRetries    = 0
    maxErrors     = '-1'

    // Default resources (conservative for 16GB machine)
    cpus   = { Math.min(2 * task.attempt, params.max_cpus ?: 8) }
    memory = { 4.GB }
    time   = { 4.h }

    // Resource labels
    withLabel:process_single {
        cpus   = { Math.min(1, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 4.h }
    }

    withLabel:process_low {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 4.GB }
        time   = { 4.h }
    }

    withLabel:process_medium {
        cpus   = { Math.min(4, params.max_cpus ?: 8) }
        memory = { 8.GB }
        time   = { 8.h }
    }

    withLabel:process_high {
        cpus   = { Math.min(6, params.max_cpus ?: 8) }
        memory = { 12.GB }
        time   = { 16.h }
    }

    withLabel:process_long {
        time   = { 20.h }
    }

    withLabel:process_high_memory {
        cpus   = { Math.min(4, params.max_cpus ?: 8) }
        memory = { 14.GB }
        time   = { 20.h }
    }

    // Specific process resource allocations (16GB RAM optimized)
    withName: 'FASTQC' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 2.h }
    }

    withName: 'FASTP' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 4.GB }
        time   = { 2.h }
    }

    withName: 'BWA_MEM2' {
        cpus   = { Math.min(6, params.max_cpus ?: 8) }
        memory = { 8.GB }
        time   = { 12.h }
    }

    withName: 'SAMTOOLS_SORT' {
        cpus   = { Math.min(4, params.max_cpus ?: 8) }
        memory = { 6.GB }
        time   = { 6.h }
    }

    withName: 'SAMTOOLS_INDEX' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 4.GB }
        time   = { 2.h }
    }

    withName: 'DEEPVARIANT' {
        cpus   = { Math.min(6, params.max_cpus ?: 8) }
        memory = { 10.GB }
        time   = { 16.h }
    }

    withName: 'MULTIQC' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 4.GB }
        time   = { 2.h }
    }

    // ============================================================
    //  QC CHECKPOINT PROCESSES
    // ============================================================
    withName: 'SAMTOOLS_FLAGSTAT' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 1.h }
    }

    withName: 'SAMTOOLS_STATS' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 1.h }
    }

    withName: 'SAMTOOLS_IDXSTATS' {
        cpus   = { Math.min(1, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 1.h }
    }

    withName: 'BAM_QC' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 4.GB }
        time   = { 2.h }
    }

    withName: 'BCFTOOLS_STATS' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 1.h }
    }

    withName: 'VCF_VALIDATION' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 1.h }
    }

    withName: 'FASTQ_VALIDATION' {
        cpus   = { Math.min(2, params.max_cpus ?: 8) }
        memory = { 2.GB }
        time   = { 1.h }
    }
}
