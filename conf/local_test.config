/*
 * ========================================
 *  Local test configuration (no containers)
 * ========================================
 */

params {
    config_profile_name        = 'Local test profile'
    config_profile_description = 'Minimal local test without containers'
    
    // Input samplesheet
    input       = "${projectDir}/test_data/test_samplesheet.csv"
    
    // Reference
    fasta       = "${projectDir}/test_data/ref.fa"
    
    // Test parameters
    seq_type    = "wes"
    target_bed  = "${projectDir}/test_data/ref.fa.bed"
    
    // Skip heavy steps for testing
    skip_deepvariant = true
    skip_multiqc     = true
}

// Disable containers for local test
process {
    container = null
    conda = null
}
