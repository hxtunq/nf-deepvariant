/*
 * ========================================
 *  Module-specific configuration
 * ========================================
 */

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // ============================================================
    //  FASTQC
    // ============================================================
    withName: 'FASTQC_RAW' {
        ext.args = '--quiet'
        ext.prefix = { "${meta.id}.raw_fastqc" }
        publishDir = [
            [ path: { "${params.outdir}/fastqc" }, mode: params.publish_dir_mode, pattern: '*.html' ],
            [ path: { "${params.outdir}/fastqc" }, mode: params.publish_dir_mode, pattern: '*.zip'  ]
        ]
    }

    withName: 'FASTQC_TRIMMED' {
        ext.args = '--quiet'
        ext.prefix = { "${meta.id}.trimmed_fastqc" }
        publishDir = [
            [ path: { "${params.outdir}/fastqc" }, mode: params.publish_dir_mode, pattern: '*.html' ],
            [ path: { "${params.outdir}/fastqc" }, mode: params.publish_dir_mode, pattern: '*.zip'  ]
        ]
    }

    // ============================================================
    //  FASTP (Trimming)
    // ============================================================
    withName: 'FASTP' {
        ext.args = [
            '--detect_adapter_for_pe',
            (!params.adapter_fasta && !params.adapter_sequence && !params.adapter_sequence_r2 && params.adapter_preset == 'illumina') ? '--adapter_sequence AGATCGGAAGAGCACACGTCTGAACTCCAGTCA --adapter_sequence_r2 AGATCGGAAGAGCGTCGTGTAGGGAAAGAGTGT' : '',
            params.adapter_fasta ? "--adapter_fasta ${params.adapter_fasta}" : '',
            params.adapter_sequence ? "--adapter_sequence ${params.adapter_sequence}" : '',
            params.adapter_sequence_r2 ? "--adapter_sequence_r2 ${params.adapter_sequence_r2}" : '',
            params.fastp_extra_args
        ].join(' ').trim()
        ext.prefix = { "${meta.id}.trimmed" }
        publishDir = [
            [ path: { "${params.outdir}/fastp" }, mode: params.publish_dir_mode, pattern: '*.html' ],
            [ path: { "${params.outdir}/fastp" }, mode: params.publish_dir_mode, pattern: '*.json' ]
        ]
    }

    // ============================================================
    //  BWA-MEM2 Alignment
    // ============================================================
    withName: 'BWA_MEM2_INDEX' {
        publishDir = [
            path: { "${params.outdir}/reference/bwa_mem2_index" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'BWA_MEM2' {
        ext.args   = '-M'
        ext.prefix = { "${meta.id}.aligned" }
        publishDir = [
            path: { "${params.outdir}/bwa_mem2" },
            mode: params.publish_dir_mode,
            pattern: '*.log'
        ]
    }

    // ============================================================
    //  SAMTOOLS
    // ============================================================
    withName: 'SAMTOOLS_SORT' {
        ext.args   = '-m 4G'
        ext.prefix = { "${meta.id}.sorted" }
        publishDir = [
            path: { "${params.outdir}/samtools" },
            mode: params.publish_dir_mode
        ]
    }

    withName: 'SAMTOOLS_INDEX' {
        ext.args   = ''
        publishDir = [
            path: { "${params.outdir}/samtools" },
            mode: params.publish_dir_mode
        ]
    }

    // ============================================================
    //  SAMTOOLS QC CHECKPOINTS
    // ============================================================
    withName: 'SAMTOOLS_FLAGSTAT' {
        ext.prefix = { "${meta.id}" }
        publishDir = [
            path: { "${params.outdir}/samtools_qc" },
            mode: params.publish_dir_mode,
            pattern: '*.flagstat'
        ]
    }

    withName: 'SAMTOOLS_STATS' {
        ext.prefix = { "${meta.id}" }
        publishDir = [
            path: { "${params.outdir}/samtools_qc" },
            mode: params.publish_dir_mode,
            pattern: '*.stats'
        ]
    }

    withName: 'SAMTOOLS_IDXSTATS' {
        ext.prefix = { "${meta.id}" }
        publishDir = [
            path: { "${params.outdir}/samtools_qc" },
            mode: params.publish_dir_mode,
            pattern: '*.idxstats'
        ]
    }

    withName: 'BAM_QC' {
        ext.prefix = { "${meta.id}" }
        publishDir = [
            [ path: { "${params.outdir}/samtools_qc" }, mode: params.publish_dir_mode, pattern: '*.flagstat' ],
            [ path: { "${params.outdir}/samtools_qc" }, mode: params.publish_dir_mode, pattern: '*.stats' ],
            [ path: { "${params.outdir}/samtools_qc" }, mode: params.publish_dir_mode, pattern: '*.idxstats' ],
            [ path: { "${params.outdir}/samtools_qc" }, mode: params.publish_dir_mode, pattern: '*.summary.txt' ]
        ]
    }

    // ============================================================
    //  BCFTOOLS VCF QC CHECKPOINTS
    // ============================================================
    withName: 'BCFTOOLS_STATS' {
        ext.prefix = { "${meta.id}" }
        publishDir = [
            path: { "${params.outdir}/vcf_qc" },
            mode: params.publish_dir_mode,
            pattern: '*.bcftools_stats.txt'
        ]
    }

    withName: 'VCF_VALIDATION' {
        ext.prefix = { "${meta.id}" }
        publishDir = [
            path: { "${params.outdir}/vcf_qc" },
            mode: params.publish_dir_mode,
            pattern: '*.validation.txt'
        ]
    }

    // ============================================================
    //  FASTQ VALIDATION
    // ============================================================
    withName: 'FASTQ_VALIDATION' {
        ext.prefix = { "${meta.id}" }
        publishDir = [
            path: { "${params.outdir}/fastq_qc" },
            mode: params.publish_dir_mode,
            pattern: '*.summary.txt'
        ]
    }

    // ============================================================
    //  DeepVariant
    // ============================================================
    withName: 'DEEPVARIANT' {
        publishDir = [
            path: { "${params.outdir}/deepvariant" },
            mode: params.publish_dir_mode,
            pattern: '*.vcf.gz*'
        ]
    }

    // ============================================================
    //  MULTIQC
    // ============================================================
    withName: 'MULTIQC' {
        ext.args   = params.multiqc_config ? "--config ${params.multiqc_config}" : ''
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode
        ]
    }

    // ============================================================
    //  CUSTOM_DUMPSOFTWAREVERSIONS
    // ============================================================
    withName: 'CUSTOM_DUMPSOFTWAREVERSIONS' {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: params.publish_dir_mode,
            pattern: '*_versions.yml'
        ]
    }
}
