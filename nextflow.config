/*
 * ========================================
 *  Cấu hình pipeline WES/WGS DeepVariant
 * ========================================
 */

// Tham số mặc định toàn pipeline.
params {
    // Đầu vào / đầu ra
    input                       = null      // Đường dẫn samplesheet CSV
    outdir                      = "./results"
    
    // Hệ tham chiếu
    fasta                       = null      // Đường dẫn FASTA tham chiếu
    fasta_fai                   = null      // Đường dẫn FASTA index; tự tạo nếu chưa truyền
    // Vùng bắt giữ exome; bắt buộc với WES
    target_bed                  = null      // Đường dẫn file BED vùng bắt giữ
    
    // Kiểu dữ liệu: 'wes' hoặc 'wgs'
    seq_type                    = "wes"     // Mặc định: WES
    
    // Tham số DeepVariant
    dv_model_type               = null      // Ghi đè model: WGS, WES, PACBIO...; nếu null sẽ suy ra từ seq_type
    dv_version                  = "1.10.0"  // Phiên bản Docker image DeepVariant
    dv_num_shards               = null      // Số shard để chạy song song; mặc định bằng task.cpus
    dv_gvcf                     = true      // Xuất thêm gVCF
    dv_extra_args               = ""        // Tham số bổ sung cho DeepVariant
    
    // Tham số BWA-MEM2; mặc định phù hợp máy 4 core / 8 thread.
    bwa_mem2_sort_threads       = 4
    bwa_mem2_sort_memory        = "6.GB"
    
    // Các bước có thể bỏ qua.
    skip_fastqc                 = false
    skip_trim                   = false
    skip_deepvariant            = false
    skip_multiqc                = false
    
    // Tham số trim bằng fastp.
    fastp_extra_args            = ""
    adapter_preset              = "illumina" // Giá trị: illumina, none
    adapter_sequence            = null      // Adapter tùy chỉnh cho read 1
    adapter_sequence_r2         = null      // Adapter tùy chỉnh cho read 2
    adapter_fasta               = null      // File FASTA adapter tùy chỉnh

    // Giới hạn tài nguyên tối đa; chỉnh theo máy đang chạy.
    // Mặc định hướng tới máy 16GB RAM, 4 core / 8 thread.
    max_cpus                    = 8
    max_memory                  = 14.GB
    max_time                    = 240.h
    
    // MultiQC
    multiqc_config              = null
    
    // Tùy chọn chung.
    publish_dir_mode            = "copy"
    email                       = null
    email_on_fail               = null
    plaintext_email             = false
    monochrome_logs             = false
    help                        = false
    version                     = "1.0.0"
    validate_params             = true
    show_hidden_params          = false
    schema_ignore_params        = 'custom_config'
}

// Nạp cấu hình tài nguyên mặc định.
includeConfig 'conf/base.config'

// Nạp cấu hình riêng cho các module DSL2.
includeConfig 'conf/modules.config'

// Các profile chạy.
profiles {
    debug {
        dumpHashes             = true
        process.beforeScript   = 'echo $HOSTNAME'
        cleanup                = false
        nextflow.enable.configProcessNamesValidation = true
    }
    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    mamba {
        conda.enabled          = true
        conda.useMamba         = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    docker {
        docker.enabled         = true
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    arm {
        docker.runOptions      = '-u $(id -u):$(id -g) --platform=linux/amd64'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    podman {
        podman.enabled         = true
        docker.enabled         = false
        singularity.enabled    = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    shifter {
        shifter.enabled        = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    charliecloud {
        charliecloud.enabled   = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        apptainer.enabled      = false
    }
    apptainer {
        apptainer.enabled      = true
        apptainer.autoMounts   = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
    }
    test      { includeConfig 'conf/test.config'      }
}

// Giữ lỗi của lệnh bên trái khi dùng pipe trong process.
process.shell = ['/bin/bash', '-euo', 'pipefail']

// Tắt cảnh báo selector process khi dùng alias/module cục bộ.
nextflow.enable.configProcessNamesValidation = false

// Báo cáo thực thi.
params.report   = params.report   ?: "${params.outdir}/pipeline_info/execution_report.html"
params.timeline = params.timeline ?: "${params.outdir}/pipeline_info/execution_timeline.html"
params.trace    = params.trace    ?: "${params.outdir}/pipeline_info/execution_trace.txt"
params.dag      = params.dag      ?: "${params.outdir}/pipeline_info/pipeline_dag.html"

manifest {
    name            = 'nf-deepvariant'
    author          = 'hxtunq'
    homePage        = 'https://github.com/hxtunq/nf-deepvariant'
    description     = 'Pipeline gọi biến thể WES/WGS bằng DeepVariant'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}
