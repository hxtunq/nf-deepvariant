/*
 * ========================================
 *  WES/WGS DeepVariant Pipeline - Configuration
 * ========================================
 */

// Global default params
params {
    // Input/Output
    input                       = null      // Path to samplesheet CSV
    outdir                      = "./results"
    
    // Reference genome
    fasta                       = null      // Path to reference FASTA
    fasta_fai                   = null      // Path to reference FASTA index (auto-generated if not provided)
    // Exome target regions (required for WES mode)
    target_bed                  = null      // Path to exome capture target BED file
    
    // Sequencing type: 'wes' or 'wgs'
    seq_type                    = "wes"     // Default: WES
    
    // DeepVariant parameters
    dv_model_type               = null      // Override model type: WGS, WES, PACBIO, etc. (auto-set from seq_type if null)
    dv_version                  = "1.10.0"  // DeepVariant Docker image version
    dv_num_shards               = null      // Number of shards for parallelization (default: task.cpus)
    dv_gvcf                     = true      // Generate gVCF output
    dv_extra_args               = ""        // Additional DeepVariant arguments
    
    // BWA-MEM2 parameters (optimized for 4 cores / 8 threads)
    bwa_mem2_sort_threads       = 4
    bwa_mem2_sort_memory        = "6.GB"
    
    // Skip steps (optional)
    skip_fastqc                 = false
    skip_trim                   = false
    skip_deepvariant            = false
    skip_multiqc                = false
    
    // Trimming parameters (fastp)
    fastp_extra_args            = ""
    adapter_preset              = "illumina" // Options: illumina, none
    adapter_sequence            = null      // Custom read 1 adapter sequence
    adapter_sequence_r2         = null      // Custom read 2 adapter sequence
    adapter_fasta               = null      // Custom adapter sequences

    // Max resource limits (adjust for your machine)
    // Current: 16GB RAM, 4 cores / 8 threads
    max_cpus                    = 8
    max_memory                  = 14.GB
    max_time                    = 240.h
    
    // MultiQC
    multiqc_config              = null
    
    // Boilerplate options
    publish_dir_mode            = "copy"
    email                       = null
    email_on_fail               = null
    plaintext_email             = false
    monochrome_logs             = false
    help                        = false
    version                     = "1.0.0"
    validate_params             = true
    show_hidden_params          = false
    schema_ignore_params        = 'custom_config'
}

// Load base.config by default for all pipelines
includeConfig 'conf/base.config'

// Load modules config for DSL2 module specific options
includeConfig 'conf/modules.config'

// Load test config if profile is test
profiles {
    debug {
        dumpHashes             = true
        process.beforeScript   = 'echo $HOSTNAME'
        cleanup                = false
        nextflow.enable.configProcessNamesValidation = true
    }
    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    mamba {
        conda.enabled          = true
        conda.useMamba         = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    docker {
        docker.enabled         = true
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    arm {
        docker.runOptions      = '-u $(id -u):$(id -g) --platform=linux/amd64'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    podman {
        podman.enabled         = true
        docker.enabled         = false
        singularity.enabled    = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    shifter {
        shifter.enabled        = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    charliecloud {
        charliecloud.enabled   = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        apptainer.enabled      = false
    }
    apptainer {
        apptainer.enabled      = true
        apptainer.autoMounts   = true
        docker.enabled         = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
    }
    test      { includeConfig 'conf/test.config'      }
}

// Capture exit codes from upstream processes when piping
process.shell = ['/bin/bash', '-euo', 'pipefail']

// Disable process selector warnings
nextflow.enable.configProcessNamesValidation = false

// Reporting
params.report   = params.report   ?: "${params.outdir}/pipeline_info/execution_report.html"
params.timeline = params.timeline ?: "${params.outdir}/pipeline_info/execution_timeline.html"
params.trace    = params.trace    ?: "${params.outdir}/pipeline_info/execution_trace.txt"
params.dag      = params.dag      ?: "${params.outdir}/pipeline_info/pipeline_dag.html"

manifest {
    name            = 'nf-deepvariant'
    author          = 'hxtunq'
    homePage        = 'https://github.com/hxtunq/nf-deepvariant'
    description     = 'WES/WGS variant calling pipeline with DeepVariant'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}
